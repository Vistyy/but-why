{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/rule-pack-schema.json",
  "version": 1,
  "name": "but-why-architecture",
  "description": "Project architecture rules that complement Fallow import boundaries.",
  "rules": [
    {
      "id": "pure-domain-no-node-infrastructure-imports",
      "kind": "banned-import",
      "specifiers": [
        "node:fs",
        "node:fs/promises",
        "fs",
        "fs/promises",
        "node:child_process",
        "child_process",
        "node:process",
        "process",
        "node:sqlite"
      ],
      "zones": ["pure-task-domain", "pure-run-domain"],
      "message": "Pure domain modules must stay free of filesystem, process execution, process, and SQLite imports.",
      "severity": "error"
    },
    {
      "id": "node-sqlite-only-in-persistence-source",
      "kind": "banned-import",
      "specifiers": ["node:sqlite"],
      "files": ["src/**/*.ts"],
      "exclude": ["src/sqlite/**/*.ts", "src/init/stateDatabase.ts"],
      "message": "Direct node:sqlite imports in production source are limited to SQLite persistence and storage initialization modules.",
      "severity": "error"
    },
    {
      "id": "task-store-implementation-does-not-import-run-store",
      "kind": "banned-import",
      "specifiers": ["../run/runStore.js", "../sqlite/sqliteRunStore.js"],
      "files": ["src/task/taskStore.ts", "src/sqlite/sqliteTaskStore.ts"],
      "message": "TaskStore must not read RunStore data. Compose Task and Run views outside the TaskStore implementation.",
      "severity": "error"
    },
    {
      "id": "run-store-implementation-does-not-import-task-store",
      "kind": "banned-import",
      "specifiers": ["../task/taskStore.js", "../sqlite/sqliteTaskStore.js"],
      "files": ["src/run/runStore.ts", "src/sqlite/sqliteRunStore.ts"],
      "message": "RunStore must not depend on TaskStore behavior. The submit-start helper is the only temporary cross-store exception.",
      "severity": "error"
    }
  ]
}
