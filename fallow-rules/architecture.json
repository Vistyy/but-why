{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/rule-pack-schema.json",
  "version": 1,
  "name": "but-why-architecture",
  "description": "Project architecture rules that complement Fallow import boundaries.",
  "rules": [
    {
      "id": "pure-domain-no-node-infrastructure-imports",
      "kind": "banned-import",
      "specifiers": [
        "node:fs",
        "node:fs/promises",
        "fs",
        "fs/promises",
        "node:child_process",
        "child_process",
        "node:process",
        "process",
        "node:sqlite"
      ],
      "zones": ["domain"],
      "message": "Domain modules must stay free of filesystem, process execution, process, and SQLite imports.",
      "severity": "error"
    },
    {
      "id": "node-sqlite-only-in-persistence-source",
      "kind": "banned-import",
      "specifiers": ["node:sqlite"],
      "files": ["src/**/*.ts"],
      "exclude": ["src/sqlite/**/*.ts", "src/init/stateDatabase.ts"],
      "message": "Direct node:sqlite imports in production source are limited to SQLite persistence and storage initialization modules.",
      "severity": "error"
    },
    {
      "id": "task-store-implementation-does-not-import-validation-run-store",
      "kind": "banned-import",
      "specifiers": [
        "../validationRun/validationRunStore.js",
        "../sqlite/sqliteValidationRunStore.js"
      ],
      "files": ["src/task/taskStore.ts", "src/sqlite/sqliteTaskStore.ts"],
      "message": "TaskStore must not read ValidationRunStore data. Compose Task and Validation Run views outside the TaskStore implementation.",
      "severity": "error"
    },
    {
      "id": "validation-run-store-implementation-does-not-import-task-store",
      "kind": "banned-import",
      "specifiers": ["../task/taskStore.js", "../sqlite/sqliteTaskStore.js"],
      "files": [
        "src/validationRun/validationRunStore.ts",
        "src/sqlite/sqliteValidationRunStore.ts"
      ],
      "message": "ValidationRunStore must not depend on TaskStore behavior. ValidationRuns owns validation start coordination.",
      "severity": "error"
    },
    {
      "id": "concrete-sqlite-stores-only-in-repo-local-storage-wiring",
      "kind": "banned-import",
      "specifiers": [
        "./sqliteTaskStore.js",
        "./sqliteValidationRunStore.js",
        "./sqliteValidationRuns.js",
        "../sqlite/sqliteTaskStore.js",
        "../sqlite/sqliteValidationRunStore.js",
        "../sqlite/sqliteValidationRuns.js",
        "../../sqlite/sqliteTaskStore.js",
        "../../sqlite/sqliteValidationRunStore.js",
        "../../sqlite/sqliteValidationRuns.js",
        "../../../sqlite/sqliteTaskStore.js",
        "../../../sqlite/sqliteValidationRunStore.js",
        "../../../sqlite/sqliteValidationRuns.js"
      ],
      "files": ["src/**/*.ts"],
      "exclude": ["src/init/repoLocalStores.ts"],
      "message": "Production code must open concrete SQLite stores only through src/init/repoLocalStores.ts.",
      "severity": "error"
    },
    {
      "id": "command-code-does-not-import-output-serializers",
      "kind": "banned-import",
      "specifiers": [
        "./output/json.js",
        "./output/serialize.js",
        "./output/toon.js",
        "../output/json.js",
        "../output/serialize.js",
        "../output/toon.js",
        "../../output/json.js",
        "../../output/serialize.js",
        "../../output/toon.js",
        "../../../output/json.js",
        "../../../output/serialize.js",
        "../../../output/toon.js"
      ],
      "files": ["src/cli*.ts", "src/cli/**/*.ts", "src/submit/submitCli.ts"],
      "message": "CLI command code may use structured output types but must leave JSON, TOON, and serializer implementation imports at the process edge.",
      "severity": "error"
    },
    {
      "id": "submit-and-validation-do-not-bypass-validation-runs",
      "kind": "banned-import",
      "specifiers": [
        "./sqliteValidationRuns.js",
        "../sqlite/sqliteValidationRuns.js",
        "../../sqlite/sqliteValidationRuns.js",
        "../../../sqlite/sqliteValidationRuns.js"
      ],
      "files": ["src/submit/**/*.ts", "src/localSubmit/**/*.ts", "src/validation/**/*.ts"],
      "message": "Submit and validation flow must start validation through the ValidationRuns seam, not by importing the SQLite implementation directly.",
      "severity": "error"
    }
  ]
}
