{
  "$schema": "https://biomejs.dev/schemas/2.5.1/schema.json",
  "files": {
    "includes": [
      "*.md",
      "*.json",
      ".but-why/config.json",
      ".fallowrc.jsonc",
      "ast-grep/tests/README.md",
      "docs/**/*.md",
      "fallow-rules/**/*.json",
      "src/**/*.ts",
      "test/**/*.ts",
      "vitest.config.ts",
      "!node_modules",
      "!dist",
      "!build",
      "!coverage",
      "!spikes"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "suspicious": {
        "noExplicitAny": "error"
      },
      "style": {
        "noNonNullAssertion": "error"
      },
      "performance": {
        "noBarrelFile": "error"
      }
    }
  },
  "overrides": [
    {
      "includes": ["src/**/*.ts"],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "error"
          }
        }
      }
    }
  ],
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  }
}
