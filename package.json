{
  "name": "but-why",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.0",
  "bin": {
    "by": "./dist/main.js"
  },
  "files": [
    "dist",
    "docs/public",
    "README.md"
  ],
  "engines": {
    "node": ">=24.0.0 <25"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "just build",
    "docs-check": "remark --frail --quiet",
    "format": "biome format --write .",
    "format-check": "biome format .",
    "lint": "biome lint .",
    "ast-grep-check": "ast-grep test && ast-grep scan",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-hero/sandcastle": "0.12.0",
    "@effect/sql": "0.50.0",
    "@effect/sql-sqlite-node": "0.51.0",
    "@toon-format/toon": "^2.3.0",
    "effect": "3.20.0"
  },
  "devDependencies": {
    "@ast-grep/cli": "^0.44.1",
    "@biomejs/biome": "^2.2.0",
    "@effect/vitest": "0.28.0",
    "@types/node": "^24.0.0",
    "@vitest/coverage-istanbul": "3.2.6",
    "fallow": "^3.2.0",
    "remark-cli": "^12.0.1",
    "remark-validate-links": "^13.1.0",
    "tsx": "^4.20.3",
    "typescript": "^7.0.2",
    "vitest": "^3.2.4"
  }
}
